generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum UserRole { SUPER_ADMIN ORG_ADMIN PROJECT_MANAGER TEAM_MEMBER CLIENT }
enum ProjectStatus { NOT_STARTED ACTIVE AT_RISK BLOCKED COMPLETED ARCHIVED }
enum TaskStatus { BACKLOG TODO IN_PROGRESS IN_REVIEW BLOCKED DONE }
enum Priority { LOW MEDIUM HIGH CRITICAL }
enum ApprovalStatus { PENDING APPROVED REJECTED CHANGES_REQUESTED }

model Tenant {
  id String @id @default(cuid())
  name String
  slug String @unique
  domain String?
  users User[]
  projects Project[]
  workflows Workflow[]
  integrations Integration[]
  createdAt DateTime @default(now())
}
model User {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields:[tenantId], references:[id])
  email String
  name String
  role UserRole
  memberships Membership[]
  reportedTasks Task[] @relation("Reporter")
  assignedTasks Task[] @relation("Assignee")
  @@unique([tenantId, email])
}
model Membership { id String @id @default(cuid()) tenantId String userId String projectId String role UserRole tenant Tenant @relation(fields:[tenantId], references:[id]) user User @relation(fields:[userId], references:[id]) project Project @relation(fields:[projectId], references:[id]) }
model Project {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields:[tenantId], references:[id])
  name String
  description String
  clientName String
  ownerId String
  owner User @relation(fields:[ownerId], references:[id])
  startDate DateTime
  dueDate DateTime
  status ProjectStatus
  priority Priority
  tasks Task[]
  milestones Milestone[]
  reports Report[]
  comments Comment[]
}
model Task { id String @id @default(cuid()) tenantId String projectId String project Project @relation(fields:[projectId], references:[id]) title String description String assigneeId String? assignee User? @relation("Assignee", fields:[assigneeId], references:[id]) reporterId String reporter User @relation("Reporter", fields:[reporterId], references:[id]) status TaskStatus priority Priority dueDate DateTime labels Label[] comments Comment[] estimatedHours Float actualHours Float? aiSummary String? blockedReason String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt }
model Comment { id String @id @default(cuid()) tenantId String content String isInternal Boolean @default(true) taskId String? projectId String? task Task? @relation(fields:[taskId], references:[id]) project Project? @relation(fields:[projectId], references:[id]) createdAt DateTime @default(now()) }
model Attachment { id String @id @default(cuid()) tenantId String taskId String fileName String fileUrl String }
model Milestone { id String @id @default(cuid()) tenantId String projectId String project Project @relation(fields:[projectId], references:[id]) title String dueDate DateTime status String }
model Label { id String @id @default(cuid()) tenantId String name String color String tasks Task[] }
model Workflow { id String @id @default(cuid()) tenantId String tenant Tenant @relation(fields:[tenantId], references:[id]) name String states Json transitions Json }
model Notification { id String @id @default(cuid()) tenantId String userId String channel String event String read Boolean @default(false) }
model AgentSuggestion { id String @id @default(cuid()) tenantId String projectId String? type String title String content String status String @default("PENDING") createdAt DateTime @default(now()) }
model Report { id String @id @default(cuid()) tenantId String projectId String type String title String summary String content Json createdAt DateTime @default(now()) }
model Client { id String @id @default(cuid()) tenantId String userId String accessScope Json }
model ApprovalRequest { id String @id @default(cuid()) tenantId String projectId String type String title String description String status ApprovalStatus @default(PENDING) }
model Integration { id String @id @default(cuid()) tenantId String tenant Tenant @relation(fields:[tenantId], references:[id]) provider String enabled Boolean @default(false) config Json }
model SubscriptionPlan { id String @id @default(cuid()) name String @unique maxUsers Int maxProjects Int clientPortal Boolean aiFeatures Boolean reportGeneration Boolean integrations Boolean customDomain Boolean prioritySupport Boolean }
model AuditLog { id String @id @default(cuid()) tenantId String actorId String action String entityType String entityId String metadata Json createdAt DateTime @default(now()) }
